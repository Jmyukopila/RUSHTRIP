# ─── Travelpayouts / Aviasales ─────────────────────────────────────
# Registro: https://travelpayouts.com
# Token desde el panel de APIs. Soporta multi-key (TOKEN_2, _3, etc.)
# El sistema rota automaticamente si una key recibe 429.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# ─── RapidAPI - Booking.com (obsoleto, quota agotada) ────────────
# https://rapidapi.com/DataCrawler/api/booking-com15
RAPIDAPI_KEY=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# ─── Hotels.nl API (datos reales de hoteles + comisiones) ─────────
# Registro: https://hotels.nl/api/register.php (20 segundos, gratis)
# 200 requests/dia gratis. Booking endpoint requiere cuenta verificada.
HOTELSNL_API_KEY=

# ─── Pexels API (fotos de hoteles) ───────────────────────────────
# Registro: https://pexels.com/api (gratis, 200 req/hora)
PEXELS_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────
# Dominios permitidos separados por coma. * para desarrollo.
CORS_ORIGINS=*

# ─── Debug ────────────────────────────────────────────────────────
DEBUG=true
