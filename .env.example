# ─── Travelpayouts / Aviasales ─────────────────────────────────────
# Registro: https://travelpayouts.com
# Token desde el panel de APIs. Soporta multi-key (TOKEN_2 y TOKEN_3):
# el sistema rota automaticamente si una key recibe 401/403/429.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_TOKEN_2=
TRAVELPAYOUTS_TOKEN_3=
TRAVELPAYOUTS_MARKER=

# Link de afiliado de Travelpayouts para hoteles. Prefijo del link de afiliado
# generado en tu panel, SIN el "&u=..." final. El sistema le agrega
# "&u=<url-del-hotel>" para deep-linkear a la ficha de cada hotel y generar comision.
#
# DEJAR VACIO EN DESARROLLO: el boton "Reservar" cae a Booking.com directo (deep-link
# a la ficha del hotel con fechas cargadas, sin comision y sin requerir aprobacion).
#
# Para ACTIVAR comision (solo en produccion, sitio en vivo): Travelpayouts NO aprueba
# proyectos en desarrollo ni permite localhost. Una vez el sitio este publico y
# aprobado por un programa de hoteles (ej. ZenHotels, mismo inventario Worldota que
# Hotels.nl; o Booking/Agoda), genera el link de afiliado LARGO (no el corto tpo.li)
# hacia cualquier hotel y pega aqui TODO menos el "&u=...".
# Ejemplo: https://tp.media/r?marker=723238&trs=12345&p=8310&campaign_id=541
TRAVELPAYOUTS_HOTEL_LINK=

# ─── RapidAPI - Booking.com (obsoleto, quota agotada) ────────────
# https://rapidapi.com/DataCrawler/api/booking-com15
# Soporta multi-key (KEY_2 y KEY_3) con rotacion en 401/403/429.
RAPIDAPI_KEY=
RAPIDAPI_KEY_2=
RAPIDAPI_KEY_3=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# ─── Hotels.nl API (datos reales de hoteles + comisiones) ─────────
# Registro: https://hotels.nl/api/register.php (20 segundos, gratis)
# 200 requests/dia gratis. Booking endpoint requiere cuenta verificada.
HOTELSNL_API_KEY=

# ─── Pexels API (fotos de hoteles) ───────────────────────────────
# Registro: https://pexels.com/api (gratis, 200 req/hora)
PEXELS_API_KEY=

# ─── OpenTripMap API (mejores actividades del destino) ───────────
# Registro: https://dev.opentripmap.org (gratis)
# Sin key, las actividades degradan a una seleccion curada local.
OPENTRIPMAP_API_KEY=

# ─── Supabase (usuarios / sesiones / reservas en la nube) ─────────
# Almacenamiento HIBRIDO: cache y rate-limiter siguen en SQLite local; las
# cuentas, sesiones, destinos preferidos y reservas van a Supabase (Postgres).
# Si SUPABASE_DB_URL queda VACIO, todo degrada a SQLite local (la app sigue
# funcionando sin credenciales, como el resto de integraciones).
#
# SUPABASE_DB_URL: connection string del POOLER (Dashboard > Project Settings >
# Database > Connection string > "Transaction pooler"). Formato:
#   postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
# URL del proyecto (informativa): https://<ref>.supabase.co
SUPABASE_URL=

# ─── Email (recuperacion de contrasena y verificacion) ───────────
# Si NO configuras SMTP, los correos NO se envian: su contenido (con el enlace)
# se registra en el log del servidor. Util en desarrollo; el flujo funciona igual.
# Para enviar de verdad en produccion, completa host/usuario/password de tu SMTP
# (SendGrid, Mailgun, Amazon SES, Postmark, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=RushTrip <rushtripsupport@gmail.com>

# URL publica del frontend, usada para construir los enlaces de los correos
# (reset-password / verificar-email). En produccion: https://tu-dominio.com
APP_BASE_URL=http://localhost:5173

# ─── CORS ─────────────────────────────────────────────────────────
# Dominios permitidos separados por coma. * para desarrollo.
CORS_ORIGINS=*

# ─── Debug ────────────────────────────────────────────────────────
# DEBUG=true tambien DESACTIVA el rate limiting por IP (comodo en local,
# donde todo sale de 127.0.0.1 y se agota el cupo diario). En PRODUCCION
# usar DEBUG=false para mantener la proteccion diaria por IP.
DEBUG=true
