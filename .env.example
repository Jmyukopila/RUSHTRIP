# Credenciales Travelpayouts (https://travelpayouts.com)
# Soporte multi-key para rotacion: agregar TRAVELPAYOUTS_TOKEN_2, _3, etc.
# El sistema rotara automaticamente si una key falla con 429.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_TOKEN_2=
TRAVELPAYOUTS_TOKEN_3=
TRAVELPAYOUTS_MARKER=

# Credenciales RapidAPI - Booking.com (https://rapidapi.com/DataCrawler/api/booking-com15)
# Soporte multi-key: agregar RAPIDAPI_KEY_2, _3, etc.
RAPIDAPI_KEY=
RAPIDAPI_KEY_2=
RAPIDAPI_KEY_3=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# Produccion: dominios permitidos separados por coma (ej: https://midominio.com)
# Desarrollo: dejar como * o comentar
CORS_ORIGINS=*

# Modo debug (true/false)
DEBUG=true
